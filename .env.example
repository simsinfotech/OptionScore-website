# ─────────────────────────────────────────────────────────────────────────
# OptionScore — environment variables
# Copy this file to `.env.local` (gitignored) and fill in real values.
# In production, set the same variables in your Vercel project settings.
# ─────────────────────────────────────────────────────────────────────────

# ── Razorpay ──────────────────────────────────────────────────────────────
# ONE switch decides everything: test vs live. Set this to "live" only when
# you actually want to charge real money. With "test", the app REFUSES to run
# if a live key is configured (and vice versa) — no silent live charges.
RAZORPAY_MODE=test

# Test credentials (rzp_test_...). The Key ID is sent to the browser by the
# order API; the Secret must NEVER reach the client.
RAZORPAY_TEST_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_TEST_KEY_SECRET=your_test_key_secret

# Live credentials (rzp_live_...). Fill these only for production.
RAZORPAY_LIVE_KEY_ID=rzp_live_xxxxxxxxxxxxxx
RAZORPAY_LIVE_KEY_SECRET=your_live_key_secret

# Webhook signing secrets (per mode) for /api/razorpay/webhook. Must match the
# secret you set when creating the webhook in the Razorpay dashboard.
RAZORPAY_TEST_WEBHOOK_SECRET=choose-a-test-webhook-secret
RAZORPAY_LIVE_WEBHOOK_SECRET=choose-a-live-webhook-secret

# Hosted payment links (OPTIONAL). The funnel pays via embedded checkout and
# does NOT use these — they exist only for sharing a link manually. Keep test
# and live links separate so the wrong one is never shared.
RAZORPAY_TEST_PAYMENT_LINK_MASTERCLASS=
RAZORPAY_TEST_PAYMENT_LINK_WORKSHOP=
RAZORPAY_LIVE_PAYMENT_LINK_MASTERCLASS=
RAZORPAY_LIVE_PAYMENT_LINK_WORKSHOP=

# ── Google Sheet (Apps Script Web App) ────────────────────────────────────
# Deploy apps-script/Code.gs as a Web App and paste its /exec URL here.
# APPS_SCRIPT_TOKEN must match the SHARED_TOKEN constant inside the script.
# The masterclass and workshop each write to their OWN spreadsheet, so deploy
# Code.gs twice (once bound to each sheet) and paste each /exec URL below.
# Both deployments can share the same SHARED_TOKEN / APPS_SCRIPT_TOKEN.
APPS_SCRIPT_URL=https://script.google.com/macros/s/XXXXXXXX/exec
APPS_SCRIPT_URL_WORKSHOP=https://script.google.com/macros/s/YYYYYYYY/exec
APPS_SCRIPT_TOKEN=choose-a-long-random-string

# ── Meta (Facebook) Pixel ─────────────────────────────────────────────────
# Public — exposed to the browser. Loads site-wide and fires PageView / Lead /
# InitiateCheckout / Purchase events. Optional: the account default is baked in.
NEXT_PUBLIC_META_PIXEL_ID=968938805962385

# ── Resend (transactional email) ──────────────────────────────────────────
# Create the key at https://resend.com. The FROM address domain must be
# verified in Resend (e.g. optionscore.app). For quick local tests you may use
# "OptionScore <onboarding@resend.dev>" which only delivers to your own email.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=OptionScore <noreply@optionscore.app>
